<entities>
	<!-- increase zombie loot drops -->
	<set xpath="/entity_classes/entity_class[contains(@name, 'zombie')]/property[contains(@name, 'LootDropProb')]/@value">.07</set>
	<!-- zombie nerfs -->
	<!-- slow tf down -->
	<append xpath="/entity_classes/entity_class[contains(@name, 'zombie')]">
		<property name="WalkSpeed" operation="perc_subtract" value="0.3" />
		<property name="RunSpeed" operation="perc_subtract" value="0.3" />
		<property name="MoveSpeedAggro" operation="perc_subtract" value="0.2" />
		<property name="MoveSpeedPanic" operation="perc_subtract" value="0.2" />
	</append>
	<!-- no climbing -->
	<set xpath="/entity_classes/entity_class[@name='zombieTemplateMale']/property[@name='CanClimbLadders']/@value">
		false
	</set>
	<set xpath="/entity_classes/entity_class[@name='zombieTemplateMale']/property[@name='SwimSpeed']/@value">
		0.5
	</set>
	<set xpath="/entity_classes/entity_class[@name='zombieTemplateMale']/property[@name='SwimStrokeRate']/@value">
		0.5, 1
	</set>
	<set xpath="/entity_classes/entity_class[@name='zombieTemplateMale']/property[@name='JumpMaxDistance']/@value">
