<entities>
	<!-- increase zombie loot drops -->
	<set xpath="/entity_classes/entity_class[contains(@name, 'zombie')]/property[contains(@name, 'LootDropProb')]/@value">.07</set>
	<!-- zombie nerfs -->
	<!-- no climbing -->
	<set xpath="/entity_classes/entity_class[@name='zombieTemplateMale']/property[@name='CanClimbLadders']/@value">
		false
	</set>
	<set xpath="/entity_classes/entity_class[@name='zombieTemplateMale']/property[@name='SwimSpeed']/@value">
		0.5
	</set>
	<set xpath="/entity_classes/entity_class[@name='zombieTemplateMale']/property[@name='SwimStrokeRate']/@value">
		0.5, 1
	</set>
	<!-- persistent corpses  -->
	<set xpath="/entity_classes/entity_class[@name='zombieTemplateMale']/property[@name='TimeStayAfterDeath']/@value">
		9000
	</set>
	<set xpath="/entity_classes/entity_class[@name='animalTemplateTimid']/property[@name='TimeStayAfterDeath']/@value">
		9000
	</set>
	<set xpath="/entity_classes/entity_class[@name='animalStag']/property[@name='TimeStayAfterDeath']/@value">
		9000
	</set>
	<!-- no screamers -->
	<set xpath="/entity_classes/entity_class[@name='zombieScreamer']/effect_group[@name='Base Effects']/passive_effect[@name='HealthMax']/@value">
		0
	</set>
	<set xpath="/entity_classes/entity_class[@extends='zombieScreamer']/effect_group[@name='Base Effects']/passive_effect[@name='HealthMax']/@value">
		0
	</set>
	<!-- boom headshot -->
	<append xpath="/entity_classes/entity_class[@name='playerMale']/effect_group">
		<passive_effect name="DamageModifier" operation="perc_subtract" value="0.9" tags="chest,legs,arms" />
		<passive_effect name="DamageModifier" operation="perc_add" value="2" tags="head" />
	</append>
	<set xpath="/entity_classes/entity_class/property[@name='DismemberMultiplierHead']/@value">
		2
	</set>
	<set xpath="/entity_classes/entity_class/property[@name='HeadExplosionDamageMultiplier']/@value">
		2
	</set>
	<!-- Remove all XP gained from selling items to traders -->
	<append xpath="/entity_classes/entity_class[@name='playerMale']">
		<effect_group name="Remove Trader XP">
			<passive_effect name="PlayerExpGain" operation="base_set" value="0" tags="Selling"/>
		</effect_group>
	</append>
</entities>