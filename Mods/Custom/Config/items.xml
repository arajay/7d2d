	<!-- add slashing damage type to axes -->
	<append xpath="/items/item[contains(@name,'meleeToolAxe')]/property[@class='Action0']">
		<property name="Damage_type" value="Slashing"/>
	</append>
	<append xpath="/items/item[@name='meleeToolRepairT0StoneAxe']/property[@class='Action0']">
		<property name="Damage_type" value="Slashing"/>
	</append>

	<!-- stun baton fixes  -->
	<append xpath="/items/item[@name='meleeWpnBatonT2StunBaton']/effect_group[@name='increase charges']">
		<triggered_effect trigger="onSelfEquipStart" action="SetItemMetaFloat" change="4" relative="false" key="charge">
			<requirement name="ProgressionLevel" progression_name="perkIntellectMastery" operation="Equals" value="5"/>
		</triggered_effect>
	</append>
	<append xpath="/items/item[@name='meleeWpnBatonT2StunBaton']/effect_group[@name='increase charges']">
		<triggered_effect trigger="onSelfEquipStart" action="AddPart" part="Sparks" prefab="@:ParticleEffects/p_electric_shock_small.prefab" parentTransform="Handle" localPos="0,0,0" localRot="0,0,0">
			<requirement name="ProgressionLevel" progression_name="perkIntellectMastery" operation="Equals" value="5"/>
		</triggered_effect>
	</append>
	<append xpath="/items/item[@name='meleeWpnBatonT2StunBaton']/effect_group[@name='increase charges']">
		<triggered_effect trigger="onSelfPrimaryActionRayHit" action="SetItemMetaFloat" change="4" relative="false" key="charge">
			<requirement name="ProgressionLevel" progression_name="perkIntellectMastery" operation="Equals" value="5"/>
			<requirement name="IsAlive" target="other"/>
			<requirement name="!EntityTagCompare" target="other" tags="trader"/>
		</triggered_effect>
	</append>
	<append xpath="/items/item[@name='meleeWpnBatonT2StunBaton']/effect_group[@name='increase charges']">
		<triggered_effect trigger="onSelfSecondaryActionRayHit" action="SetItemMetaFloat" change="4" relative="false" key="charge">
			<requirement name="ProgressionLevel" progression_name="perkIntellectMastery" operation="Equals" value="5"/>
			<requirement name="IsAlive" target="other"/>
			<requirement name="!EntityTagCompare" target="other" tags="trader"/>
		</triggered_effect>
	</append>
	<append xpath="/items/item[@name='meleeWpnBatonT2StunBaton']/effect_group[@name='increase charges']">
		<triggered_effect trigger="onSelfPrimaryActionRayHit" action="AddPart" part="Sparks" prefab="@:ParticleEffects/p_electric_shock_small.prefab" parentTransform="Handle" localPos="0,0,0" localRot="0,0,0">
			<requirement name="ProgressionLevel" progression_name="perkIntellectMastery" operation="Equals" value="5"/>
			<requirement name="IsAlive" target="other"/>
			<requirement name="!EntityTagCompare" target="other" tags="trader"/>
		</triggered_effect>
	</append>
	<append xpath="/items/item[@name='meleeWpnBatonT2StunBaton']/effect_group[@name='increase charges']">
		<triggered_effect trigger="onSelfSecondaryActionRayHit" action="AddPart" part="Sparks" prefab="@:ParticleEffects/p_electric_shock_small.prefab" parentTransform="Handle" localPos="0,0,0" localRot="0,0,0">
			<requirement name="ProgressionLevel" progression_name="perkIntellectMastery" operation="Equals" value="5"/>
			<requirement name="IsAlive" target="other"/>
			<requirement name="!EntityTagCompare" target="other" tags="trader"/>
		</triggered_effect>
	</append>

	<!-- Increases damage for arrows and bolts to make archery more effective -->

	<!-- Stone Arrow: Increase EntityDamage from 35 to 49 -->
	<set xpath="/items/item[@name='ammoArrowStone']/effect_group[@name='ammoArrowStone']/passive_effect[@name='EntityDamage' and @operation='base_set']/@value">49</set>

	<!-- Iron Arrow: Increase EntityDamage from 38 to 68 -->
	<set xpath="/items/item[@name='ammoArrowIron']/effect_group[@name='ammoArrowIron']/passive_effect[@name='EntityDamage' and @operation='base_set']/@value">68</set>

	<!-- Steel AP Arrow: Increase EntityDamage from 42 to 92 -->
	<set xpath="/items/item[@name='ammoArrowSteelAP']/effect_group[@name='ammoArrowSteelAP']/passive_effect[@name='EntityDamage' and @operation='base_set']/@value">92</set>

	<!-- Stone Crossbow Bolt: Increase EntityDamage from 50 to 58 -->
	<set xpath="/items/item[@name='ammoCrossbowBoltStone']/effect_group[@name='ammoCrossbowBoltStone']/passive_effect[@name='EntityDamage' and @operation='base_set']/@value">58</set>

	<!-- Iron Crossbow Bolt: Increase EntityDamage from 59 to 100 -->
	<set xpath="/items/item[@name='ammoCrossbowBoltIron']/effect_group[@name='ammoCrossbowBoltIron']/passive_effect[@name='EntityDamage' and @operation='base_set']/@value">100</set>

	<!-- Steel AP Crossbow Bolt: Increase EntityDamage from 63 to 142 -->
	<set xpath="/items/item[@name='ammoCrossbowBoltSteelAP']/effect_group[@name='ammoCrossbowBoltSteelAP']/passive_effect[@name='EntityDamage' and @operation='base_set']/@value">142</set>

	<!-- Flaming Crossbow Bolt: Increase EntityDamage from 38 to 68 -->
	<set xpath="/items/item[@name='ammoCrossbowBoltFlaming']/effect_group[@name='ammoCrossbowBoltFlaming']/passive_effect[@name='EntityDamage' and @operation='base_set']/@value">68</set>

	<!-- Flaming Arrow: Increase EntityDamage from 25 to 38 -->
	<set xpath="/items/item[@name='ammoArrowFlaming']/effect_group[@name='ammoArrowFlaming']/passive_effect[@name='EntityDamage' and @operation='base_set']/@value">38</set>

	<!-- Exploding Arrow: Increase EntityDamage from 180 to 220 -->
	<set xpath="/items/item[@name='ammoArrowExploding']/effect_group[@name='ammoArrowExploding']/passive_effect[@name='EntityDamage' and @operation='base_set']/@value">220</set>

	<!-- Exploding Crossbow Bolt: Increase EntityDamage from 250 to 270 -->
	<set xpath="/items/item[@name='ammoCrossbowBoltExploding']/effect_group[@name='ammoCrossbowBoltExploding']/passive_effect[@name='EntityDamage' and @operation='base_set']/@value">270</set>

	<!-- Wooden Bow: Increase EntityDamage base_add from 9 to 19 -->
	<set xpath="/items/item[@name='gunBowT1WoodenBow']/effect_group[@name='gunBowT1WoodenBow']/passive_effect[@name='EntityDamage' and @operation='base_add']/@value">19</set>

	<!-- Compound Bow: Increase EntityDamage base_add from 29 to 51 -->
	<set xpath="/items/item[@name='gunBowT3CompoundBow']/effect_group[@name='gunBowT3CompoundBow']/passive_effect[@name='EntityDamage' and @operation='base_add']/@value">51</set>

	<!-- Compound Crossbow: Increase EntityDamage base_add from 25 to 50 -->
	<set xpath="/items/item[@name='gunBowT3CompoundCrossbow']/effect_group[@name='gunBowT3CompoundCrossbow']/passive_effect[@name='EntityDamage' and @operation='base_add']/@value">50</set>

</configs>